---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];
import { getLangFromUrl} from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const { title, description, pubDate, updatedDate, heroImage,customURL,faqs} = Astro.props;
const image = "https://marcmayol.com/" + heroImage
const datePublished = new Date(pubDate).toISOString()
const currentURL = Astro.url
const backLabel = lang === 'es' ? '← VOLVER AL BLOG' : '← BACK TO BLOG';
const item= {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	"mainEntityOfPage": {
		"@type": "WebPage",
		"@id":currentURL,
	},
	"headline": title,
	"description": description,
	"image": image,
	"author": {
		"@type": "Person",
		"name": "Marc Mayol Orell",
		"url": "https://marcmayol.com/about"
	},
	"publisher": {
		"@type": "Organization",
		"name": "Marc Mayol Orell",
		"logo": {
			"@type": "ImageObject",
			"url": "https://marcmayol.com/logo512.png"
		}
	},
	"datePublished": {datePublished },
}
---

<html lang={lang}>
	<head>
		<BaseHead title={title} description={description} image={heroImage} item={item}/>
	</head>

	<body class="mm-body">
		<Header customURL={customURL}/>
		<article class="mm-article">
			<div class="mm-article-head">
				<a class="mm-article-back" href={`/blog/${lang}/`}>{backLabel}</a>
				<h1 class="mm-article-title">{title}</h1>
				<div class="mm-article-meta"><FormattedDate date={pubDate}/></div>
			</div>

			{heroImage &&
				<img class="mm-article-hero" width={1020} height={510} src={heroImage} alt={title} title={title}/>}

			<div id="post-content" class="mm-article-body">
				<slot/>
				{faqs && (
					<script type="application/ld+json" is:inline set:html={JSON.stringify({
						"@context": "https://schema.org",
						"@type": "FAQPage",
						"mainEntity": faqs.map(i => ({
							"@type": "Question",
							"name": i.pregunta,
							"acceptedAnswer": { "@type": "Answer", "text": i.respuesta }
						}))
					})} />
				)}
			</div>
		</article>
		<Footer />
	</body>
</html>

<style is:global>
	body.mm-body{margin:0;background:#f2f0eb}
</style>

<style>
	.mm-article{
		max-width:860px;margin:0 auto;background:#f2f0eb;color:#141110;
		border-left:2px solid #141110;border-right:2px solid #141110;
		font-family:'Archivo',sans-serif;
	}
	.mm-article-head{padding:48px 44px 32px;border-bottom:2px solid #141110}
	.mm-article-back{
		font-family:'Space Mono',monospace;font-size:12px;font-weight:700;
		color:#d62828;text-decoration:none;display:inline-block;margin-bottom:22px;
	}
	.mm-article-back:hover{text-decoration:underline}
	.mm-article-title{font-size:40px;font-weight:900;line-height:1.06;letter-spacing:-.02em;margin:0 0 16px}
	.mm-article-meta{font-family:'Space Mono',monospace;font-size:12px;color:#888}
	.mm-article-hero{display:block;width:100%;height:auto;border-bottom:2px solid #141110}
	.mm-article-body{
		padding:40px 44px 56px;
		font-size:17px;line-height:1.78;color:#2a2724;
	}
	@media (max-width:760px){
		.mm-article-head{padding:36px 22px 26px}
		.mm-article-title{font-size:30px}
		.mm-article-body{padding:30px 22px 44px;font-size:16px}
	}
</style>
