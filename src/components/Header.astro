---
import { changeroutelang, getLangFromUrl, useTranslations } from '../i18n/utils';
import { languages } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Props {
	customURL?: string;
}
const { customURL } = Astro.props as Props;
---

<header class="mm-header">
	<a href={`/${lang}`} class="mm-logo">MARC_MAYOL<span class="mm-red">.COM</span></a>
	<nav class="mm-nav" aria-label="Main Navigation">
		<a href={`/about/${lang}/`} class="mm-navlink" title={t('nav.about')}>{t('nav.about')}</a>
		<a href={`/${lang}#servicios`} class="mm-navlink" title={t('nav.services')}>{t('nav.services')}</a>
		<a href={`/blog/${lang}/`} class="mm-navlink" title={t('nav.blog')}>{t('nav.blog')}</a>
		<a href={`/contacto/${lang}/`} class="mm-navlink mm-navlink--cta" title={t('nav.contact')}>{t('nav.contact')}</a>
		<span class="mm-lang">
			{Object.entries(languages).map(([code, label]) => (
				code === lang ? (
					<span class="mm-lang-btn" data-active="1" aria-current="true">{code.toUpperCase()}</span>
				) : (
					<a class="mm-lang-btn" href={changeroutelang(Astro.url, code, customURL)} title={`Cambiar a ${label}`}>{code.toUpperCase()}</a>
				)
			))}
		</span>
	</nav>
</header>

<style>
	.mm-header{
		max-width:1180px;margin:0 auto;
		display:flex;justify-content:space-between;align-items:center;
		padding:16px 32px;
		background:#fff;color:#141110;
		border-bottom:2px solid #141110;border-left:2px solid #141110;border-right:2px solid #141110;
		position:sticky;top:0;z-index:50;
		font-family:'Space Mono',monospace;
	}
	.mm-logo{
		text-decoration:none;font-weight:700;font-size:15px;letter-spacing:.02em;color:#141110;
	}
	.mm-red{color:#d62828}
	.mm-nav{display:flex;align-items:center;gap:0;font-size:12px}
	.mm-navlink{
		text-decoration:none;padding:6px 14px;color:#141110;
		border-left:1px solid #e2ddd3;transition:background .15s;
		text-transform:uppercase;white-space:nowrap;
	}
	.mm-navlink:hover{background:#f2f0eb}
	.mm-navlink--cta{background:#d62828;color:#fff}
	.mm-navlink--cta:hover{background:#141110}
	.mm-lang{display:inline-flex;margin-left:14px;font-weight:700;border:1px solid #141110}
	.mm-lang-btn{
		border:none;background:none;padding:6px 9px;cursor:pointer;font:inherit;
		color:#141110;text-decoration:none;
	}
	.mm-lang-btn + .mm-lang-btn{border-left:1px solid #141110}
	.mm-lang-btn[data-active="1"]{background:#141110;color:#fff}
	@media (max-width:760px){
		.mm-header{flex-direction:column;gap:12px;padding:14px 16px}
		.mm-nav{flex-wrap:wrap;justify-content:center}
	}
</style>
