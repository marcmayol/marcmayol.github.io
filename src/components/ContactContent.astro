---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import ContactForm from './ContactForm.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const channels = [
	{ id: 'email', label: 'EMAIL', value: 'marcmayolorell@gmail.com', href: 'mailto:marcmayolorell@gmail.com', external: false },
	{ id: 'linkedin', label: 'LINKEDIN', value: 'in/marc-mayol-orell', href: 'https://www.linkedin.com/in/marc-mayol-orell/', external: true },
	{ id: 'github', label: 'GITHUB', value: 'github.com/marcmayol', href: 'https://github.com/marcmayol', external: true },
];
---

<div class="mm-contactpage">

	<!-- HERO -->
	<section class="mm-cp-hero">
		<span class="mm-badge">{t('contact.badge')}<i class="mm-caret"></i></span>
		<h1 class="mm-cp-h1" set:html={t('contact.h1')}></h1>
		<p class="mm-cp-intro">{t('contact.intro')}</p>
	</section>

	<!-- FORMULARIO + CANALES -->
	<section class="mm-cp-grid">
		<div class="mm-cp-formcell">
			<ContactForm />
		</div>

		<div class="mm-cp-side">
			{channels.map((channel) => (
				<a
					href={channel.href}
					class="mm-chan"
					{...(channel.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
				>
					<div class="mm-chan-top">
						<div class="mm-chan-id">
							{channel.id === 'email' && (
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#141110" stroke-width="2" stroke-linecap="square" aria-hidden="true">
									<rect x="2" y="4" width="20" height="16"></rect>
									<path d="M2 6l10 7 10-7"></path>
								</svg>
							)}
							{channel.id === 'linkedin' && (
								<svg width="20" height="20" viewBox="0 0 24 24" fill="#141110" aria-hidden="true">
									<path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.55C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.72C24 .77 23.2 0 22.22 0z"></path>
								</svg>
							)}
							{channel.id === 'github' && (
								<svg width="20" height="20" viewBox="0 0 24 24" fill="#141110" aria-hidden="true">
									<path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.26.8-.57v-2c-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5 1 .1-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.12-3.18 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.28-1.55 3.29-1.23 3.29-1.23.66 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.8 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .31.2.68.82.57A12 12 0 0 0 12 .3z"></path>
								</svg>
							)}
							<span class="mm-chan-label">{channel.label}</span>
						</div>
						<span class="mm-chan-arw">→</span>
					</div>
					<div class="mm-chan-val">{channel.value}</div>
				</a>
			))}

			<div class="mm-direct">
				<div class="mm-direct-badge">{t('contact.directbadge')}</div>
				<div class="mm-direct-text">{t('contact.directtext')}</div>
			</div>
		</div>
	</section>

</div>

<style>
	.mm-contactpage{
		max-width:1180px;margin:0 auto;background:#f2f0eb;color:#141110;
		border-left:2px solid #141110;border-right:2px solid #141110;
		font-family:'Archivo',sans-serif;
	}
	.mm-red{color:#d62828}

	/* HERO */
	.mm-cp-hero{padding:60px 40px;border-bottom:2px solid #141110}
	.mm-badge{
		font-family:'Space Mono',monospace;font-size:12px;background:#141110;color:#fff;
		display:inline-block;padding:5px 11px;margin-bottom:24px;
	}
	.mm-caret{
		display:inline-block;width:7px;height:13px;background:#d62828;
		margin-left:6px;vertical-align:middle;animation:mm-blink 1.1s steps(1) infinite;
	}
	@keyframes mm-blink{0%,49%{opacity:1}50%,100%{opacity:0}}
	.mm-cp-h1{
		font-size:66px;line-height:.94;font-weight:900;letter-spacing:-.03em;
		margin:0 0 20px;text-transform:uppercase;
	}
	.mm-cp-intro{
		font-family:'Space Mono',monospace;font-size:15px;line-height:1.65;
		color:#333;max-width:600px;margin:0;
	}

	/* GRID */
	.mm-cp-grid{display:grid;grid-template-columns:1.15fr .85fr;border-bottom:2px solid #141110}
	.mm-cp-formcell{padding:44px 40px;border-right:2px solid #141110;min-width:0}
	.mm-cp-side{display:flex;flex-direction:column;min-width:0}

	/* CANALES */
	.mm-chan{
		text-decoration:none;color:inherit;
		padding:28px 32px;border-bottom:2px solid #141110;
		transition:background .12s;
	}
	.mm-chan:hover{background:#fff}
	.mm-chan:hover .mm-chan-arw{color:#d62828}
	.mm-chan-top{display:flex;justify-content:space-between;align-items:center}
	.mm-chan-id{display:flex;align-items:center;gap:12px}
	.mm-chan-label{font-family:'Space Mono',monospace;font-size:11px;font-weight:700;color:#d62828}
	.mm-chan-arw{font-family:'Space Mono',monospace;color:#888;transition:color .12s}
	.mm-chan-val{font-family:'Space Mono',monospace;font-size:14px;margin-top:8px;word-break:break-all}

	/* BLOQUE DIRECTO */
	.mm-direct{
		padding:28px 32px;background:#141110;color:#fff;
		flex:1;display:flex;flex-direction:column;justify-content:center;
	}
	.mm-direct-badge{font-family:'Space Mono',monospace;font-size:11px;font-weight:700;color:#ff8a8a;margin-bottom:12px}
	.mm-direct-text{font-weight:800;font-size:22px;text-transform:uppercase;line-height:1.05}

	/* RESPONSIVE */
	@media (max-width:860px){
		.mm-cp-hero{padding:44px 24px}
		.mm-cp-h1{font-size:46px}
		.mm-cp-grid{grid-template-columns:1fr}
		.mm-cp-formcell{border-right:none;border-bottom:2px solid #141110;padding:36px 24px}
		.mm-chan{padding:24px}
		.mm-direct{padding:28px 24px}
	}
	@media (max-width:520px){
		.mm-cp-h1{font-size:38px}
	}
</style>
