---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AboutContent from '../../../components/AboutContent.astro';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const item = {
	'@context': 'https://schema.org',
	'@type': 'AboutPage',
	"name": "About me - Marc Mayol",
	"alternativeName": "About me -Marc Mayol Orell",
	"description": "Personal website of Marc Mayol Orell, AI engineer and educator. Discover his background, projects, and publications.",
	"author": {
		"@type": "Person",
		"name": "Marc Mayol Orell",
		"url": "https://marcmayol.com",
		"sameAs": [
			"https://www.linkedin.com/in/marc-mayol-orell/",
			"https://github.com/marcmayol"
		],
		"knowsAbout": [
			"python",
			"google products",
			"Generative AI",
			"javascript",
			"vertexai",
			"OpenAi",
			"Prompt Engineering",
		]
	},
	"mainEntity": {
		"@type": "Person",
		"name": "Marc Mayol Orell",
		"jobTitle": "AI engineer and educator",
		"image": "https://marcmayol.com/images/perfil.jpg",
		"description": "Marc Mayol, specialist in generative artificial intelligence, product development, and AI education.",
		"url": "https://marcmayol.com"
	}
}
---

<!doctype html>
<html lang={lang}>
<head>
	<BaseHead title="About me - Marc Mayol"
			  description="Personal website of Marc Mayol Orell, AI engineer and educator. Discover his background, projects, and publications."
			  item={item} image="/perfil.png"/>
</head>
<body class="mm-body">
<Header customURL="/about/es/" />
<AboutContent>
	<div class="mm-story-block">
		<div class="mm-story-media"><img src="/fotoarearea.jpg" alt="Aerial view of Palma" /></div>
		<div>
			<h3 class="mm-story-h">My story</h3>
			<p class="mm-story-t">
				Ever since I was a kid growing up in Mallorca, I've had an insatiable curiosity for understanding how things work. I used to take apart toys, electronic devices and pretty much anything that landed in my hands, not to break them, but to uncover their inner workings and learn. That same curiosity is what eventually led me to become an engineer and, later on, to dedicate myself to the world of artificial intelligence.
				<br /><br />
				Today, I'm an AI developer and educator. I combine technical development with teaching because I firmly believe that knowledge, when shared, multiplies. I'm passionate about creating solutions that truly work — ones that go beyond being flashy to become genuinely useful tools.
			</p>
		</div>
	</div>

	<div class="mm-story-block mm-story-block--rev">
		<div class="mm-story-media"><img src="/GitHub__headpic.webp" alt="PromptSuite" /></div>
		<div>
			<h3 class="mm-story-h">PromptSuite</h3>
			<p class="mm-story-t">
				One of the projects that best represents this way of working is PromptSuite, a library I developed to manage prompts in a structured way, with specific versions for each model, in both JSON and SQL formats. It was born out of a real need, and I designed it with versatility, security and clarity in mind for anyone who uses it.
				<br /><br />
				<strong>Coming soon.</strong>
			</p>
		</div>
	</div>

	<div class="mm-story-block">
		<div class="mm-story-media">
			<figure>
				<img src="/20f5d489-5e90-4cd0-906a-e58353358e9b.png" alt="IA-chan" />
				<figcaption>IA-chan, my trusty companion who helps me with my AI classes and articles.</figcaption>
			</figure>
		</div>
		<div>
			<h3 class="mm-story-h">My content</h3>
			<p class="mm-story-t">
				I write articles, create content and take part in initiatives where AI isn't just a trend, but a purposeful tool. I'm especially interested in how intelligent agents can become useful, valuable and marketable products for businesses.
				<br /><br />
				I keep learning every day, exploring new paths and sharing what I discover. If there's one thing I've learned along the way, it's that technology only makes sense when it improves people's lives.
			</p>
		</div>
	</div>
</AboutContent>
<Footer/>
</body>
</html>

<style is:global>
	body.mm-body{margin:0;background:#f2f0eb}
</style>
